# Copy this file to .env and fill in your own values.

# Base URL of the data-engine FastAPI backend (data-engine/main.py).
# The CollegeFootballData API key lives ONLY on the backend now —
# do not put a CFBD key in any VITE_* variable (those end up in the browser bundle).
VITE_API_BASE_URL=http://localhost:8000
