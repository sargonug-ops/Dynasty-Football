# Copy this file to .env and fill in your own values.

# Optional. Leave unset to use same-origin `/api`:
#   - Local: Vite proxies /api → http://localhost:8000 (uvicorn)
#   - Production: Vercel serverless functions under /api
#
# Only set this if you point at a separately hosted FastAPI backend.
# The CollegeFootballData API key lives ONLY on the server —
# do not put a CFBD key in any VITE_* variable (those end up in the browser bundle).
# VITE_API_BASE_URL=https://your-api.example.com
