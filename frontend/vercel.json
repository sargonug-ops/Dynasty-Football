{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "functions": {
    "api/health.py": {
      "includeFiles": "api/_lib/**",
      "maxDuration": 10
    },
    "api/defenses.py": {
      "includeFiles": "api/_lib/**",
      "maxDuration": 60
    },
    "api/players/advanced.py": {
      "includeFiles": "api/_lib/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
